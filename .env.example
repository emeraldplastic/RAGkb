# Runtime
APP_ENV=development

# Security
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_ISSUER=ragkb
JWT_AUDIENCE=ragkb-users
SECURITY_HEADERS_ENABLED=1
TRUSTED_HOSTS=localhost,127.0.0.1,*.vercel.app
ENABLE_CORS=1
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_ENABLED=1
AUTH_RATE_LIMIT_REQUESTS=12
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_USERNAME_RATE_LIMIT_REQUESTS=8
LOGIN_USERNAME_RATE_LIMIT_WINDOW_SECONDS=300
UPLOAD_RATE_LIMIT_REQUESTS=20
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=300
CHAT_RATE_LIMIT_REQUESTS=45
CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# Data paths
DATABASE_PATH=./ragkb.db
CHROMA_PATH=./chroma_db
UPLOAD_DIR=./uploaded_docs
MAX_UPLOAD_MB=25
MAX_FILENAME_CHARS=180
ALLOWED_EXTENSIONS=.pdf,.txt,.md

# AI provider
# Use openai for OpenAI or OpenAI-compatible APIs.
# Use google for a Gemini API key.
AI_PROVIDER=openai
LLM_PROVIDER=openai
EMBED_PROVIDER=openai

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=
EMBED_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Google Gemini
# For Gemini, set AI_PROVIDER=google and provide GOOGLE_API_KEY.
# Defaults become LLM_MODEL=gemini-1.5-flash and EMBED_MODEL=models/text-embedding-004.
GOOGLE_API_KEY=

# Retrieval
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVER_K=6
MIN_RELEVANCE_SCORE=0.2
MAX_CONTEXT_CHARS=22000
MAX_QUESTION_CHARS=2000
MAX_SOURCES_IN_RESPONSE=8
